{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://gtfs.org/schema/realtime.schema.json",
	"title": "GTFS Realtime Reference Schema",
	"description": "JSON Schema for GTFS Realtime Reference YAML structure",
	"type": "object",
	"additionalProperties": false,
	"required": ["metadata"],
	"properties": {
		"metadata": {
			"type": "object",
			"additionalProperties": false,
			"required": ["name", "revision_date", "revision_history_url", "description"],
			"properties": {
				"name": {
					"type": "string"
				},
				"revision_date": {
					"type": ["string", "null"]
				},
				"revision_history_url": {
					"type": ["string", "null"]
				},
				"description": {
					"type": "string"
				}
			}
		},
		"document_conventions": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"term_definitions": {
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"description": {
							"$ref": "#/$defs/textOrTextList"
						},
						"terms": {
							"type": "array",
							"items": {
								"$ref": "#/$defs/termDefinition"
							}
						}
					}
				}
			}
		},
		"elements": {
			"type": "array",
			"items": {
				"$ref": "#/$defs/element"
			}
		}
	},
	"$defs": {
		"textOrTextList": {
			"oneOf": [
				{
					"type": "string"
				},
				{
					"type": "array",
					"items": {
						"type": "string"
					}
				}
			]
		},
		"notesList": {
			"type": "array",
			"items": {
				"oneOf": [
					{
						"type": "string"
					},
					{
						"type": "object",
						"additionalProperties": false,
						"required": ["list"],
						"properties": {
							"list": {
								"type": "array",
								"items": {
									"type": "string"
								}
							}
						}
					}
				]
			}
		},
		"termOption": {
			"type": "object",
			"additionalProperties": false,
			"required": ["value", "definition"],
			"properties": {
				"value": {
					"type": "string"
				},
				"definition": {
					"type": "string"
				}
			}
		},
		"termDefinition": {
			"type": "object",
			"additionalProperties": false,
			"required": ["term", "definition"],
			"properties": {
				"term": {
					"type": "string"
				},
				"definition": {
					"$ref": "#/$defs/textOrTextList"
				},
				"options": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/termOption"
					}
				},
				"notes": {
					"$ref": "#/$defs/notesList"
				}
			}
		},
		"enumOption": {
			"type": "object",
			"additionalProperties": false,
			"required": ["value"],
			"properties": {
				"value": {
					"type": "string"
				},
				"description": {
					"type": "string"
				}
			}
		},
		"fieldType": {
			"oneOf": [
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["element"],
					"properties": {
						"element": {
							"type": "object",
							"additionalProperties": false,
							"required": ["name", "data_type"],
							"properties": {
								"name": {
									"type": "string"
								},
								"data_type": {
									"type": "string",
									"enum": ["message", "enum"]
								}
							}
						}
					}
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["format"],
					"properties": {
						"format": {
							"type": "object",
							"additionalProperties": false,
							"required": ["name", "reference"],
							"properties": {
								"name": {
									"type": "string"
								},
								"reference": {
									"type": "string"
								}
							}
						}
					}
				}
			]
		},
		"field": {
			"type": "object",
			"additionalProperties": false,
			"required": ["name", "type", "presence", "cardinality", "description"],
			"properties": {
				"name": {
					"type": "string"
				},
				"type": {
					"$ref": "#/$defs/fieldType"
				},
				"presence": {
					"type": "string",
					"enum": ["Required", "Optional", "Conditionally required", "Conditionally forbidden"]
				},
				"cardinality": {
					"type": "string",
					"enum": ["One", "Many"]
				},
				"description": {
					"$ref": "#/$defs/textOrTextList"
				},
				"is_experimental": {
					"type": "boolean"
				}
			}
		},
		"messageElement": {
			"type": "object",
			"additionalProperties": false,
			"required": ["name", "data_type", "description", "fields"],
			"properties": {
				"name": {
					"type": "string"
				},
				"data_type": {
					"type": "string",
					"const": "message"
				},
				"description": {
					"type": "string"
				},
				"notes": {
					"$ref": "#/$defs/notesList"
				},
				"is_experimental": {
					"type": "boolean"
				},
				"fields": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/field"
					}
				}
			}
		},
		"enumElement": {
			"type": "object",
			"additionalProperties": false,
			"required": ["name", "data_type", "options"],
			"properties": {
				"name": {
					"type": "string"
				},
				"data_type": {
					"type": "string",
					"const": "enum"
				},
				"description": {
					"type": "string"
				},
				"notes": {
					"$ref": "#/$defs/notesList"
				},
				"is_experimental": {
					"type": "boolean"
				},
				"options": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/enumOption"
					}
				}
			}
		},
		"element": {
			"oneOf": [
				{
					"$ref": "#/$defs/messageElement"
				},
				{
					"$ref": "#/$defs/enumElement"
				}
			]
		}
	}
}
